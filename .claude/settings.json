{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": [
    "grafana",
    "mysql_clientdb_altex",
    "mysql_clientdb_account",
    "mysql_clientdb_instrument"
  ],
  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Read(.envrc)"
    ],
    "allow": [
      "mcp__mysql_clientdb_altex__mysql_query",
      "mcp__mysql_clientdb_instrument__mysql_query",
      "mcp__mysql_clientdb_account__mysql_query",
      "mcp__grafana__list_datasources",
      "mcp__grafana__query_loki_logs",
      "Bash(test -n \"$ALT_AUTH_TOKEN\" && echo \"ALT_AUTH_TOKEN set (len=${#ALT_AUTH_TOKEN})\" || echo \"ALT_AUTH_TOKEN MISSING\")",
      "Bash(uv run .claude/skills/altex-triaging/scripts/collect_transfer_evidence.py:*)",
      "Bash(uv run .claude/skills/altex-triaging/scripts/collect_account_evidence.py:*)",
      "Bash(uv run .claude/skills/altex-triaging/scripts/collect_instrument_evidence.py:*)"
    ]
  },
  "autoMemoryEnabled": false
}
